{
  "expo": {
    "name": "Avengers Coffee - Customer",
    "slug": "customer-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "package": "com.avengers.coffee.customer",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Ứng dụng cần quyền microphone để đặt hàng bằng giọng nói"
      }
    },
    "splash": {
      "backgroundColor": "#f26b1d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Ứng dụng cần quyền camera để quét mã QR thanh toán",
          "microphonePermission": false
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Ứng dụng cần quyền microphone để đặt hàng bằng giọng nói"
        }
      ]
    ]
  }
}