# ============================================================================
# AVENGERS COFFEE MICROSERVICES - ENVIRONMENT CONFIGURATION
# ============================================================================
# SECURITY WARNING: This is a template. DO NOT commit actual secrets to git.
# Generate strong passwords: openssl rand -base64 32
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
# IMPORTANT: Change this to a strong password! Generate: openssl rand -base64 32
POSTGRES_PASSWORD=your_strong_postgres_password_here
POSTGRES_DB=avengers_coffee
POSTGRES_PORT=5433

DB_HOST=postgres-db
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=your_strong_postgres_password_here
DB_NAME=avengers_coffee

# ─────────────────────────────────────────────────────────────────────────
# CACHE & MESSAGE BROKER
# ─────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis-cache
REDIS_PORT=6379
REDIS_INTERNAL_PORT=6379

RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://rabbitmq:5672

# ─────────────────────────────────────────────────────────────────────────
# SERVICE PORTS
# ─────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
IDENTITY_PORT=3001
MENU_PORT=3003
INVENTORY_PORT=3004
ORDER_PORT=3005
NEWS_PORT=3006
AI_PORT=8000

# ─────────────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ─────────────────────────────────────────────────────────────────────────
# IMPORTANT: Set a strong JWT secret. Generate: openssl rand -base64 32
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d
INTERNAL_SERVICE_TOKEN=your_internal_service_token_here

# ─────────────────────────────────────────────────────────────────────────
# AI SERVICE (Gemini API)
# ─────────────────────────────────────────────────────────────────────────
# REQUIRED: Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: AI model configuration
AI_CHAT_MAX_CONTINUATION_ROUNDS=0
GEMINI_BLOCK_MINUTES_ON_429=10
CF_AUTO_RETRAIN_MINUTES=60
CF_RETRAIN_QUEUE_COOLDOWN_SECONDS=120

# ─────────────────────────────────────────────────────────────────────────
# FRONTEND (Web Apps) - URLs
# ─────────────────────────────────────────────────────────────────────────
WEB_CUSTOMER_API_URL=http://localhost:3000
WEB_CUSTOMER_SOCKET_URL=http://localhost:3005
WEB_CUSTOMER_PORT=5173

WEB_ADMIN_API_URL=http://localhost:3000
WEB_ADMIN_SOCKET_URL=http://localhost:3005
WEB_ADMIN_PORT=5174

WEB_SHIPPER_API_URL=http://localhost:3000
WEB_SHIPPER_SOCKET_URL=http://localhost:3005
WEB_SHIPPER_PORT=5175

SHIPPER_LAUNCHER_PORT=5176

# ─────────────────────────────────────────────────────────────────────────
# FRONTEND - OAuth & reCAPTCHA
# ─────────────────────────────────────────────────────────────────────────
# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
WEB_CUSTOMER_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_APP_SECRET=your_google_app_secret_here

# reCAPTCHA v3
# Get from: https://www.google.com/recaptcha/admin
WEB_CUSTOMER_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# Facebook Login
# Get from: https://developers.facebook.com/apps
WEB_CUSTOMER_FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ─────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# Use app-specific password for Gmail, not your real password
SMTP_PASS=your_app_specific_password_here
SMTP_FROM=noreply@avengers-coffee.com

# ─────────────────────────────────────────────────────────────────────────
# PAYMENT INTEGRATION
# ─────────────────────────────────────────────────────────────────────────
# VNPay (Sandbox for testing, Production when ready)
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=your_vnpay_merchant_code
# IMPORTANT: Replace with your actual VNPay hash secret, NOT the test value
VNPAY_HASH_SECRET=your_vnpay_hash_secret_here

# SePay Bank Transfer
# IMPORTANT: Set your actual webhook secret, NOT "changeme-sepay-secret"
SEPAY_WEBHOOK_SECRET=your_sepay_webhook_secret_here
SEPAY_BANK_CODE=MBBank
SEPAY_ACCOUNT_NO=025452790502

# Payment URLs
PAYMENT_RETURN_BASE_URL=http://localhost:3000
WEB_CUSTOMER_BASE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────
# DATABASE SCHEMAS (Optional: use defaults)
# ─────────────────────────────────────────────────────────────────────────
IDENTITY_DB_SCHEMA=identity
MENU_DB_SCHEMA=menu
INVENTORY_DB_SCHEMA=inventory
ORDER_DB_SCHEMA=orders
NEWS_DB_SCHEMA=news
AI_SCHEMA=ai

# ─────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────
APP_NAME=The Avengers House
NODE_ENV=production